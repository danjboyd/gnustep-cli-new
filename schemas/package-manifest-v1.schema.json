{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gnustep.example/schemas/package-manifest-v1.schema.json",
  "title": "GNUstep Package Manifest v1",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "name",
    "version",
    "kind",
    "summary",
    "license",
    "maintainers",
    "source",
    "requirements",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "kind": {
      "enum": [
        "gui-app",
        "cli-tool",
        "library",
        "template"
      ]
    },
    "summary": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "maintainers": {
      "type": "array",
      "minItems": 1
    },
    "source": {
      "type": "object",
      "required": [
        "type",
        "url",
        "sha256"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "sha256": {
          "type": "string"
        },
        "revision": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        },
        "upstream": {
          "type": "string"
        },
        "upstream_url": {
          "type": "string"
        },
        "tracking_strategy": {
          "type": "string"
        },
        "update_cadence": {
          "type": "string"
        },
        "channel_policy": {
          "type": "string"
        }
      }
    },
    "requirements": {
      "type": "object",
      "required": [
        "supported_os",
        "supported_arch",
        "supported_compiler_families",
        "supported_objc_runtimes",
        "supported_objc_abi",
        "required_features",
        "forbidden_features"
      ]
    },
    "artifacts": {
      "type": "array",
      "minItems": 1
    },
    "dependencies": {
      "type": "array"
    },
    "integration": {
      "type": "object"
    },
    "install": {
      "type": "object"
    },
    "patches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "path",
          "sha256"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          },
          "strip": {
            "type": "integer",
            "minimum": 0
          },
          "applies_to": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rationale": {
            "type": "string"
          },
          "upstream_status": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "build": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
