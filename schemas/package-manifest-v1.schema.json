{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gnustep.example/schemas/package-manifest-v1.schema.json",
  "title": "GNUstep Package Manifest v1",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "name",
    "version",
    "kind",
    "summary",
    "license",
    "maintainers",
    "source",
    "requirements",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "kind": {
      "enum": [
        "gui-app",
        "cli-tool",
        "library",
        "template"
      ]
    },
    "summary": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "maintainers": {
      "type": "array",
      "minItems": 1
    },
    "source": {
      "type": "object",
      "required": [
        "type",
        "url",
        "sha256"
      ]
    },
    "requirements": {
      "type": "object",
      "required": [
        "supported_os",
        "supported_arch",
        "supported_compiler_families",
        "supported_objc_runtimes",
        "supported_objc_abi",
        "required_features",
        "forbidden_features"
      ]
    },
    "artifacts": {
      "type": "array",
      "minItems": 1
    },
    "dependencies": {
      "type": "array"
    },
    "integration": {
      "type": "object"
    },
    "install": {
      "type": "object"
    }
  },
  "additionalProperties": true
}

